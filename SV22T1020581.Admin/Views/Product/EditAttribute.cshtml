@model SV22T1020581.Models.Catalog.ProductAttribute
@{
    var pid = Model.ProductID;
    var isNew = Model.AttributeID == 0;
}
@section PageToolBar {
    <button type="submit" form="formAttr" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>

    <a href="~/Product/Edit/@pid#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">@(isNew ? "Bổ sung thuộc tính" : "Cập nhật thuộc tính")</h5>
                @if (ViewBag.ProductName != null)
                {
                    <div class="small text-muted">Mặt hàng: <strong>@ViewBag.ProductName</strong></div>
                }
            </div>

            <div class="card-body">
                <form id="formAttr" method="post" action="@Url.Action("SaveAttribute", "Product")">
                    <input type="hidden" name="AttributeID" value="@Model.AttributeID" />
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold" for="AttributeName">Tên thuộc tính</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeName"
                                   id="AttributeName"
                                   class="form-control"
                                   value="@Model.AttributeName"
                                   placeholder="Ví dụ: Màu sắc, Kích thước, Chất liệu"
                                   required
                                   autofocus />
                            @Html.ValidationMessage("AttributeName", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold" for="AttributeValue">Giá trị</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeValue"
                                   id="AttributeValue"
                                   class="form-control"
                                   value="@Model.AttributeValue"
                                   placeholder="Ví dụ: Đỏ, XL, 500g"
                                   required />
                            @Html.ValidationMessage("AttributeValue", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold" for="DisplayOrder">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number"
                                   name="DisplayOrder"
                                   id="DisplayOrder"
                                   class="form-control"
                                   value="@(Model.DisplayOrder <= 0 ? 1 : Model.DisplayOrder)"
                                   min="1" />
                            @Html.ValidationMessage("DisplayOrder", new { @class = "text-danger small" })
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
