@{
    Layout = "_Layout";
    ViewData["Title"] = "Thanh toán — TechZone";
}
@model SV22T1020581.Shop.Controllers.CheckoutViewModel

<div class="checkout-wrap">
    <div style="font-family:var(--font-head);font-size:1.6rem;font-weight:900;margin-bottom:20px;color:var(--white);">
        🛍️ Thông tin giao hàng
    </div>

    <form asp-controller="Order" asp-action="Checkout" method="post">
        @Html.AntiForgeryToken()

        <!-- Địa chỉ giao hàng -->
        <div class="checkout-card">
            <div class="checkout-title">📍 Địa chỉ giao hàng</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Tên người nhận <span class="req">*</span></label>
                    <input class="form-control @(ViewData.ModelState.ContainsKey("CustomerName") && ViewData.ModelState["CustomerName"]!.Errors.Count > 0 ? "is-invalid" : "")"
                           name="CustomerName" value="@Model.CustomerName" autofocus placeholder="VD: Nguyễn Văn A">
                    @Html.ValidationMessage("CustomerName", new { @class = "invalid-feedback d-block", @style = "color:var(--sale);font-size:.78rem;margin-top:4px;" })
                </div>
                <div class="form-group">
                    <label>Số điện thoại <span class="req">*</span></label>
                    <input class="form-control @(ViewData.ModelState.ContainsKey("Phone") && ViewData.ModelState["Phone"]!.Errors.Count > 0 ? "is-invalid" : "")"
                           type="tel" name="Phone" value="@Model.Phone" placeholder="0901 234 567" autocomplete="tel">
                    @Html.ValidationMessage("Phone", new { @class = "invalid-feedback d-block", @style = "color:var(--sale);font-size:.78rem;margin-top:4px;" })
                </div>
            </div>
            <div class="form-row full">
                <div class="form-group">
                    <label>Địa chỉ giao hàng <span class="req">*</span></label>
                    <input class="form-control @(ViewData.ModelState.ContainsKey("Address") && ViewData.ModelState["Address"]!.Errors.Count > 0 ? "is-invalid" : "")"
                           name="Address" value="@Model.Address" placeholder="VD: 123 Đường ABC, Quận 1">
                    @Html.ValidationMessage("Address", new { @class = "invalid-feedback d-block", @style = "color:var(--sale);font-size:.78rem;margin-top:4px;" })
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Tỉnh/Thành phố <span class="req">*</span></label>
                    <input class="form-control @(ViewData.ModelState.ContainsKey("Province") && ViewData.ModelState["Province"]!.Errors.Count > 0 ? "is-invalid" : "")"
                           name="Province" value="@Model.Province" placeholder="VD: TP.HCM">
                    @Html.ValidationMessage("Province", new { @class = "invalid-feedback d-block", @style = "color:var(--sale);font-size:.78rem;margin-top:4px;" })
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input class="form-control" type="email" name="Email"
                           value="@Model.Email" readonly style="background:var(--panel);color:var(--grey);">
                </div>
            </div>
            @Html.ValidationMessage("Error", new { @style = "color:var(--sale);font-size:.84rem;display:block;margin-bottom:8px;" })
        </div>

        <!-- Tóm tắt đơn hàng -->
        <div class="checkout-card">
            <div class="checkout-title">📋 Tóm tắt đơn hàng</div>
            @if (ViewBag.Cart != null)
            {
                foreach (var item in ViewBag.Cart)
                {
                    <div class="summary-row" style="border:none;border-bottom:1px dashed var(--border);border-radius:0;padding:8px 0;">
                        <span>@item.ProductName × @item.Quantity</span>
                        <span>@item.TotalAmount.ToString("N0")đ</span>
                    </div>
                }
            }
            <div class="summary-row" style="border:none;padding:12px 0 0;">
                <span style="font-size:1rem;font-weight:700;color:var(--white);">Tổng cộng</span>
                <span style="font-family:var(--font-head);font-size:1.4rem;font-weight:900;color:var(--blue-bright);">
                    @((ViewBag.TotalAmount ?? 0).ToString("N0"))đ
                </span>
            </div>
        </div>

        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <a href="~/Cart" class="btn-outline" style="padding:13px 20px;border:1.5px solid var(--border);border-radius:var(--radius-sm);text-decoration:none;font-size:.84rem;color:var(--grey);">
                ← Quay lại giỏ hàng
            </a>
            <button type="submit" class="checkout-btn" style="flex:1;">
                ⚡ Xác nhận đặt hàng
            </button>
        </div>
    </form>
</div>