@{
    Layout = "_Layout";
    ViewData["Title"] = "Đổi mật khẩu — TechZone";
}

<div class="profile-layout">
    <!-- SIDEBAR -->
    <div class="profile-sidebar">
        <div class="profile-avatar">
            @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "?")
        </div>
        <div class="profile-name">@(User.Identity?.Name ?? "Khách hàng")</div>
        <div class="profile-email">@(User.Identity?.Name ?? "")</div>
        <ul class="profile-menu">
            <li onclick="window.location.href='/Account/Profile'" style="cursor:pointer;">
                👤 Thông tin cá nhân
            </li>
            <li onclick="window.location.href='/Account/EditProfile'" style="cursor:pointer;">✏️ Thay đổi thông tin</li>
            <li class="active">🔑 Đổi mật khẩu</li>
            <li onclick="window.location.href='/Order/MyOrders'" style="cursor:pointer;">
                📋 Đơn hàng (theo trạng thái)
            </li>
            <li onclick="window.location.href='/Order/PurchaseHistory'" style="cursor:pointer;">
                🕐 Lịch sử mua hàng
            </li>
            <li class="danger" onclick="window.location.href='/Account/Logout'" style="cursor:pointer;">
                🚪 Đăng xuất
            </li>
        </ul>
    </div>

    <!-- CONTENT -->
    <div class="profile-content">
        <div class="section-title-profile">🔑 Đổi mật khẩu</div>

        <form asp-controller="Account" asp-action="ChangePassword" method="post" style="max-width:420px;">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Mật khẩu hiện tại</label>
                <input class="form-control" type="password" name="oldPassword"
                       placeholder="••••••••" autofocus autocomplete="current-password">
            </div>
            <div class="form-group">
                <label class="form-label">Mật khẩu mới</label>
                <input class="form-control" type="password" name="newPassword"
                       placeholder="Tối thiểu 4 ký tự" autocomplete="new-password">
            </div>
            <div class="form-group">
                <label class="form-label">Xác nhận mật khẩu mới</label>
                <input class="form-control" type="password" name="confirmPassword"
                       placeholder="Nhập lại mật khẩu mới" autocomplete="new-password">
            </div>

            @Html.ValidationMessage("Error", new { @style = "color:var(--sale);font-size:.84rem;display:block;margin-bottom:8px;" })

            <div style="display:flex;gap:12px;margin-top:8px;">
                <button type="submit" class="save-btn">Cập nhật mật khẩu</button>
                <a href="~/Account/Profile"
                   style="display:inline-flex;align-items:center;padding:12px 20px;border:1.5px solid var(--border);border-radius:var(--radius-sm);text-decoration:none;font-size:.84rem;color:var(--grey);transition:var(--transition);">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>